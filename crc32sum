#!/usr/bin/env bash
# crc32sum - md5sum-like wrapper around crc32 utility from package libarchive-zip-perl
set -euo pipefail

check_file() {
    [[ -d "$1" ]] && { echo "crc32sum: $1: Is a directory" >&2; return 1; }
    [[ -e "$1" ]] || { echo "crc32sum: $1: No such file" >&2; return 1; }
    [[ -r "$1" ]] || { echo "crc32sum: $1: Permission denied" >&2; return 1; }
}

crc32_of_file() {
    local f="$1"
    local crc
    crc=$(crc32 "$f" | cut -f1 -d' ')
    printf '%s  %s\n' "$crc" "$f"
}

crc32_of_stdin() {
    local crc
    crc=$(crc32 <(cat))
    printf '%s  -\n' "$crc"
}

if [[ $# -eq 0 ]]; then
    crc32_of_stdin
else
    status=0
    for f in "$@"; do
        if [[ "$f" == "-" ]]; then
            crc32_of_stdin
            continue
        fi
        check_file "$f" || { status=1; continue; }
        crc32_of_file "$f"
    done
    exit "$status"
fi
